# ── Application ────────────────────────────────────────────────────────────────
APP_NAME="LearnLoom Scraping Engine"
APP_VERSION="1.0.0"
DEBUG=false
SECRET_KEY=change_me_to_a_long_random_string_in_production

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=learnloom
POSTGRES_PASSWORD=learnloom_secret
POSTGRES_DB=learnloom_db

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Celery ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Scraping ───────────────────────────────────────────────────────────────────
SCRAPE_CONCURRENT_REQUESTS=16
SCRAPE_DOWNLOAD_DELAY=1.0
SCRAPE_RETRY_TIMES=3
SCRAPE_TIMEOUT=30
SCRAPE_SCHEDULE_HOURS=24

# Proxy support (optional — comma-separated list)
PROXY_ENABLED=false
PROXY_LIST=

# ── AI Classification (optional — improves accuracy) ───────────────────────────
OPENAI_API_KEY=
SIMILARITY_THRESHOLD=0.85

# ── CORS ───────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ── Pagination ─────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ── Cache TTL (seconds) ────────────────────────────────────────────────────────
CACHE_TTL_RESOURCES=300
CACHE_TTL_CATEGORIES=3600
CACHE_TTL_TRENDING=600
