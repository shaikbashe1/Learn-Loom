datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  STUDENT
  INSTRUCTOR
  ORG_ADMIN
  SUPER_ADMIN
}

enum UserType {
  STUDENT
  PROFESSIONAL
  HOBBYIST
}

enum QuestionType {
  MULTIPLE_CHOICE
  MULTIPLE_SELECT
  FILL_BLANK
  MATCHING
  DRAG_DROP
  IMAGE_LABELING
  SEQUENCE_ORDERING
  CODE_OUTPUT
  TERMINAL_QUESTION
  SCENARIO_BASED
  CASE_STUDY
  SHORT_ANSWER
  ESSAY
}

enum LabStatus {
  NOT_STARTED
  IN_PROGRESS
  PASSED
  FAILED
}

// ==========================================
// 1. User & Profile Models
// ==========================================

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  passwordHash  String
  role          Role          @default(STUDENT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  profile       Profile?
  orgMembers    OrgMember[]
  enrollments   Enrollment[]
  labAttempts   LabAttempt[]
  submissions   Submission[]
  progress      Progress[]
  certificates  Certificate[]
  comments      Comment[]
  bookmarks     Bookmark[]
  notifications Notification[]
  logs          AuditLog[]

  @@index([email])
}

model Profile {
  id                 String    @id @default(uuid())
  userId             String    @unique
  fullName           String
  username           String    @unique
  avatarUrl          String?
  bio                String?
  userType           UserType  @default(STUDENT)
  credits            Int       @default(0)
  streakDays         Int       @default(0)
  lastActivityDate   DateTime?

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 2. Organization & Licensing
// ==========================================

model Organization {
  id          String      @id @default(uuid())
  name        String      @unique
  licenseKeys String[]
  seatsTotal  Int         @default(10)
  createdAt   DateTime    @default(now())

  members     OrgMember[]
  courses     Course[]
}

model OrgMember {
  id             String       @id @default(uuid())
  orgId          String
  userId         String
  joinedAt       DateTime     @default(now())

  organization   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

// ==========================================
// 3. Learning Content Models
// ==========================================

model LearningPath {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String

  courses     CoursePathLink[]
}

model Course {
  id             String             @id @default(uuid())
  orgId          String?
  title          String
  slug           String             @unique
  description    String
  difficulty     String             @default("Beginner")
  rating         Float              @default(0.0)
  isPublished    Boolean            @default(false)
  createdAt      DateTime           @default(now())

  organization   Organization?      @relation(fields: [orgId], references: [id], onDelete: SetNull)
  paths          CoursePathLink[]
  modules        Module[]
  enrollments    Enrollment[]
  certificates   Certificate[]
}

model CoursePathLink {
  id             String        @id @default(uuid())
  pathId         String
  courseId       String
  order          Int

  learningPath   LearningPath  @relation(fields: [pathId], references: [id], onDelete: Cascade)
  course         Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([pathId, courseId])
}

model Module {
  id          String       @id @default(uuid())
  courseId    String
  title       String
  order       Int
  description String

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  chapters    Chapter[]
  quizzes     Quiz[]
  assignments Assignment[]

  @@unique([courseId, order])
}

model Chapter {
  id          String   @id @default(uuid())
  moduleId    String
  title       String
  order       Int

  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessons     Lesson[]

  @@unique([moduleId, order])
}

model Lesson {
  id          String     @id @default(uuid())
  chapterId   String
  title       String
  order       Int
  content     String
  contentUrl  String?

  chapter     Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  labs        Lab[]
  progress    Progress[]
  bookmarks   Bookmark[]
  comments    Comment[]

  @@unique([chapterId, order])
}

// ==========================================
// 4. Quiz & Assessment Models
// ==========================================

model Quiz {
  id           String     @id @default(uuid())
  moduleId     String
  title        String
  passingScore Int        @default(70)
  durationMins Int        @default(30)

  module       Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions    Question[]
}

model Question {
  id           String       @id @default(uuid())
  quizId       String
  type         QuestionType
  text         String
  explanation  String?
  points       Int          @default(10)

  quiz         Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers      Answer[]
}

model Answer {
  id          String   @id @default(uuid())
  questionId  String
  text        String
  isCorrect   Boolean  @default(false)

  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// ==========================================
// 5. Code Labs & Assignments
// ==========================================

model Lab {
  id              String       @id @default(uuid())
  lessonId        String
  title           String
  instructions    String
  codeTemplate    String?
  expectedOutputs String[]

  lesson          Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts        LabAttempt[]
}

model LabAttempt {
  id           String    @id @default(uuid())
  labId        String
  userId       String
  code         String?
  shellHistory String[]
  status       LabStatus @default(IN_PROGRESS)
  score        Int       @default(0)
  submittedAt  DateTime  @default(now())

  lab          Lab       @relation(fields: [labId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, labId])
}

model Assignment {
  id          String       @id @default(uuid())
  moduleId    String
  title       String
  description String
  maxPoints   Int          @default(100)

  module      Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  submissions Submission[]
}

model Submission {
  id           String      @id @default(uuid())
  assignmentId String
  userId       String
  submissionUrl String
  grade        Int?
  comments     String?
  gradedAt     DateTime?

  assignment   Assignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, assignmentId])
}

// ==========================================
// 6. User Tracking & Achievements
// ==========================================

model Enrollment {
  id          String    @id @default(uuid())
  userId      String
  courseId    String
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Progress {
  id          String   @id @default(uuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Certificate {
  id               String   @id @default(uuid())
  userId           String
  courseId         String
  verificationCode String   @unique
  issuedAt         DateTime @default(now())
  score            Float
  isValid          Boolean  @default(true)

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([verificationCode])
}

// ==========================================
// 7. Messaging, Comments, & Bookmarks
// ==========================================

model Comment {
  id          String    @id @default(uuid())
  lessonId    String
  userId      String
  parentId    String?
  content     String
  isAccepted  Boolean   @default(false)
  createdAt   DateTime  @default(now())

  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      Comment?  @relation("Thread", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[] @relation("Thread")

  @@index([lessonId])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  lessonId  String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  content   String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==========================================
// 8. Infrastructure & Audit Logging
// ==========================================

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  ipAddress String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
